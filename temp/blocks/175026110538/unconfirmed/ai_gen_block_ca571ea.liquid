{% doc %}
  @prompt
    Una camisa rosada en venta
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-sale-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
  }

  .ai-product-sale-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.gap }}px;
    align-items: center;
  }

  .ai-product-sale-image-wrapper-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
  }

  .ai-product-sale-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    object-fit: cover;
  }

  .ai-product-sale-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-product-sale-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-sale-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    right: {{ block.settings.badge_position_right }}px;
    background-color: {{ block.settings.badge_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
  }

  .ai-product-sale-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-product-sale-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-product-sale-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  .ai-product-sale-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-sale-price-original-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.original_price_color }};
    text-decoration: line-through;
  }

  .ai-product-sale-price-sale-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size | plus: 4 }}px;
    color: {{ block.settings.sale_price_color }};
    font-weight: 700;
  }

  .ai-product-sale-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 28px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-align: center;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-product-sale-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-sale-container-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<product-sale-{{ ai_gen_id }} class="ai-product-sale-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-sale-container-{{ ai_gen_id }}">
    <div class="ai-product-sale-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product_image %}
        <img
          src="{{ block.settings.product_image | image_url: width: 800 }}"
          alt="{{ block.settings.product_image.alt | escape }}"
          class="ai-product-sale-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.product_image.width }}"
          height="{{ block.settings.product_image.height }}"
        >
      {% else %}
        <div class="ai-product-sale-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-apparel-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
      
      {% if block.settings.show_badge %}
        <div class="ai-product-sale-badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-sale-content-{{ ai_gen_id }}">
      {% if block.settings.product_title != blank %}
        <h2 class="ai-product-sale-title-{{ ai_gen_id }}">{{ block.settings.product_title }}</h2>
      {% endif %}

      {% if block.settings.product_description != blank %}
        <div class="ai-product-sale-description-{{ ai_gen_id }}">
          {{ block.settings.product_description }}
        </div>
      {% endif %}

      <div class="ai-product-sale-price-wrapper-{{ ai_gen_id }}">
        {% if block.settings.original_price != blank %}
          <span class="ai-product-sale-price-original-{{ ai_gen_id }}">{{ block.settings.original_price }}</span>
        {% endif %}
        {% if block.settings.sale_price != blank %}
          <span class="ai-product-sale-price-sale-{{ ai_gen_id }}">{{ block.settings.sale_price }}</span>
        {% endif %}
      </div>

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-product-sale-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</product-sale-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductSale{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-sale-{{ ai_gen_id }}', ProductSale{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Camisa en venta",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Producto"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Título del producto",
      "default": "Camisa rosada"
    },
    {
      "type": "richtext",
      "id": "product_description",
      "label": "Descripción",
      "default": "<p>Hermosa camisa rosada de alta calidad, perfecta para cualquier ocasión.</p>"
    },
    {
      "type": "text",
      "id": "original_price",
      "label": "Precio original",
      "default": "$50.00"
    },
    {
      "type": "text",
      "id": "sale_price",
      "label": "Precio de venta",
      "default": "$35.00"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Comprar ahora"
    },
    {
      "type": "header",
      "content": "Insignia de venta"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Mostrar insignia",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto de la insignia",
      "default": "¡OFERTA!"
    },
    {
      "type": "range",
      "id": "badge_position_top",
      "label": "Posición superior",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "badge_position_right",
      "label": "Posición derecha",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Tamaño de fuente",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Radio del borde",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Color de fondo",
      "default": "#FF1744"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Color del texto",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposición",
      "options": [
        {
          "value": "row",
          "label": "Horizontal"
        },
        {
          "value": "row-reverse",
          "label": "Horizontal invertido"
        },
        {
          "value": "column",
          "label": "Vertical"
        }
      ],
      "default": "row"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre elementos",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Relleno",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Radio del borde",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Radio del borde de imagen",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fondo",
      "default": "#FFF0F5"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color de descripción",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "original_price_color",
      "label": "Color precio original",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Color precio de venta",
      "default": "#FF1744"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Color del botón",
      "default": "#FF69B4"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Color del botón al pasar",
      "default": "#FF1493"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Color del texto del botón",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Tipografía"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Tamaño del título",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Tamaño de descripción",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "price_font_size",
      "label": "Tamaño del precio",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Tamaño del botón",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Radio del borde del botón",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Camisa en venta"
    }
  ]
}
{% endschema %}
